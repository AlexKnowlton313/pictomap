# PMTiles archive URL.
# Dev: use the Vite proxy path "/pmtiles/<YYYYMMDD>.pmtiles" — build.protomaps.com
# does not send CORS headers, so the dev server proxies it (see vite.config.ts).
# Prod: a full https URL to a CORS-enabled host (CloudFront, etc).
VITE_PMTILES_URL=/pmtiles/20260524.pmtiles

# Sentry DSN — leave blank to disable error reporting locally
VITE_SENTRY_DSN=
