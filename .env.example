# Tile manifest URL. Optional — defaults to /tiles/manifest.json, which works
# both in dev (Vite proxies /tiles/* to the production CloudFront, see
# vite.config.ts) and in prod (app and tiles share an origin).
# Set this to point at a staging or local manifest when testing tile builds.
VITE_TILES_MANIFEST_URL=

# Sentry DSN — leave blank to disable error reporting locally
VITE_SENTRY_DSN=
